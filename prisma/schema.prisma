generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  KAPRODI
  KETUA_KK
  DOSEN
  ACADEMIC
}

enum ActivityAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  IMPORT
  PLOT_ASSIGN
  PLOT_CLEAR
  OPEN_CLASS
  DLB_CREATE
  ROLE_CHANGE
  PASSWORD_RESET
}

enum SemesterTipe {
  GANJIL
  GENAP
}

enum Jenjang {
  S1
  D3
}

enum TingkatPendidikan {
  S2
  S3
  ON_GOING_S3
}

enum DosenJenis {
  TETAP
  DLB
}

model ProgramStudi {
  id      String  @id @default(cuid())
  kode    String  @unique
  nama    String
  jenjang Jenjang
  aktif   Boolean @default(true)

  dosenHomebase   Dosen[]          @relation("DosenHomebase")
  mataKuliah      MataKuliah[]
  courseOfferings CourseOffering[]
  users           User[]
  prodiTargets    ProdiTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kode])
}

model KelompokKeahlian {
  id          String  @id @default(cuid())
  nama        String  @unique
  kodeSingkat String?

  dosen Dosen[]
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nama])
}

model CenterOfExcellence {
  id   String @id @default(cuid())
  nama String @unique

  dosen Dosen[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nama])
}

model Dosen {
  id                String             @id @default(cuid())
  kode              String             @unique
  nama              String
  namaTanpaGelar    String
  email             String?            @unique
  nipYpt            String?
  nidn              String?
  jfa               String?
  tmtJfa            DateTime?
  homebaseProdiId   String?
  homebaseProdi     ProgramStudi?      @relation("DosenHomebase", fields: [homebaseProdiId], references: [id])
  tingkatPendidikan TingkatPendidikan?
  kkId              String?
  kk                KelompokKeahlian?  @relation(fields: [kkId], references: [id])
  coeId             String?
  coe               CenterOfExcellence? @relation(fields: [coeId], references: [id])
  bebanStruktural   String?
  // Numeric SKS value of the structural role (separate from the free-text
  // label above, which stays as an unmigrated legacy field).
  bebanStrukturalSks Float?
  // DLB-only in practice (nullable so TETAP rows are unaffected).
  noTelp            String?
  homebaseUniv      String?
  aktif             Boolean            @default(true)
  jenis             DosenJenis         @default(TETAP)
  // Who self-registered this dosen as a DLB (Part of Refinement 05). Null for
  // the existing/imported permanent roster and for dosen created by Admin.
  createdById       String?
  createdBy         User?              @relation("DosenRegisteredBy", fields: [createdById], references: [id])

  kelas Kelas[]
  user  User?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kode])
  @@index([homebaseProdiId])
  @@index([kkId])
  @@index([coeId])
}

model MataKuliah {
  id      String  @id @default(cuid())
  kodeMK  String
  nama    String
  sks     Float
  prodiId String
  prodi   ProgramStudi @relation(fields: [prodiId], references: [id])
  ket     String?

  courseOfferings CourseOffering[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kodeMK, prodiId])
  @@index([prodiId])
  @@index([kodeMK])
}

model SemesterPeriode {
  id                   String       @id @default(cuid())
  nama                 String
  tipe                 SemesterTipe
  tahunAjaran          String
  aktif                Boolean      @default(false)
  // When true, Kaprodi/Ketua KK can see this (non-active) semester read-only.
  visibleToScopedRoles Boolean      @default(false)

  courseOfferings CourseOffering[]
  prodiTargets    ProdiTarget[]
  kelas           Kelas[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([aktif])
}

// Configurable per-prodi, per-period staffing target ("Kebutuhan SKS"),
// mirroring row 1 of the source workbook's Beban Dosen sheet.
model ProdiTarget {
  id                String          @id @default(cuid())
  prodiId           String
  prodi             ProgramStudi    @relation(fields: [prodiId], references: [id])
  semesterPeriodeId String
  semesterPeriode   SemesterPeriode @relation(fields: [semesterPeriodeId], references: [id])
  kebutuhanSks      Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([prodiId, semesterPeriodeId])
}

model CourseOffering {
  id                String   @id @default(cuid())
  mataKuliahId      String
  mataKuliah        MataKuliah @relation(fields: [mataKuliahId], references: [id])
  semesterPeriodeId String
  semesterPeriode   SemesterPeriode @relation(fields: [semesterPeriodeId], references: [id])
  semesterKe        Int
  tahunAngkatan     Int
  prodiId           String
  prodi             ProgramStudi @relation(fields: [prodiId], references: [id])
  kelasPrefix       String

  kelas Kelas[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([semesterPeriodeId, mataKuliahId, kelasPrefix])
  @@index([semesterPeriodeId, prodiId])
  @@index([mataKuliahId])
  @@index([prodiId])
}

model Kelas {
  id                String          @id @default(cuid())
  courseOfferingId  String
  courseOffering    CourseOffering  @relation(fields: [courseOfferingId], references: [id])
  // Denormalized from courseOffering.semesterPeriodeId for direct, efficient
  // semester-scoped queries/write-guards without joining through CourseOffering.
  semesterPeriodeId String
  semesterPeriode   SemesterPeriode @relation(fields: [semesterPeriodeId], references: [id])
  kodeKelas         String
  sectionSuffix     String
  sks               Float
  dosenId           String?
  dosen             Dosen?          @relation(fields: [dosenId], references: [id])
  // Who plotted the current dosenId and when (Refinement 05). Both cleared
  // back to null whenever dosenId is cleared — they track the *current*
  // assignment's author, not a permanent history.
  assignedById      String?
  assignedBy        User?           @relation("KelasAssignedBy", fields: [assignedById], references: [id])
  assignedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseOfferingId, sectionSuffix])
  @@index([courseOfferingId])
  @@index([semesterPeriodeId])
  @@index([dosenId])
  @@index([kodeKelas])
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  name               String
  role               Role
  prodiId            String?
  prodi              ProgramStudi?     @relation(fields: [prodiId], references: [id])
  kkId               String?
  kk                 KelompokKeahlian? @relation(fields: [kkId], references: [id])
  // 1:1 with Dosen for DOSEN-role accounts. Null for non-dosen accounts
  // (the seeded bootstrap admin, or an Admin/Kaprodi/Ketua KK created
  // directly without going through dosen-account provisioning).
  dosenId            String?  @unique
  dosen              Dosen?   @relation(fields: [dosenId], references: [id])
  // True for accounts provisioned with a predictable default password
  // (derived from NIP); cleared once the user sets their own password.
  mustChangePassword Boolean  @default(false)
  aktif              Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  registeredDlb Dosen[] @relation("DosenRegisteredBy")
  assignedKelas Kelas[] @relation("KelasAssignedBy")
  activityLogs  ActivityLog[]

  @@index([prodiId])
  @@index([kkId])
}

model ActivityLog {
  id           String         @id @default(cuid())
  actorUserId  String
  actor        User           @relation(fields: [actorUserId], references: [id])
  // The effective role the action ran as -- equal to actor.role unless an
  // Admin performed it while impersonating (Refinement 16), in which case
  // this is the impersonated role and impersonatedRole/impersonatedScope
  // are also set, so "show me everything done as KAPRODI" and "show me
  // everything done via impersonation" can both be queried directly.
  actorRole         Role
  impersonatedRole  Role?
  impersonatedScope String?
  action       ActivityAction
  entityType   String
  entityId     String?
  detail       String?
  ip           String?
  createdAt    DateTime       @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}
